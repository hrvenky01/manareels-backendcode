package com.manareels.controller;

import com.manareels.service.LikeService;
import com.manareels.security.JwtUtil;
import jakarta.servlet.http.HttpServletRequest;
import org.springframework.web.bind.annotation.*;

@RestController
@RequestMapping("/api/likes")
public class LikeController {

    private final LikeService service;
    private final JwtUtil jwtUtil;

    public LikeController(LikeService service, JwtUtil jwtUtil) {
        this.service = service;
        this.jwtUtil = jwtUtil;
    }

    @PostMapping("/{postId}")
    public String toggleLike(@PathVariable Long postId,
                             HttpServletRequest request) {

    	String token = request.getHeader("Authorization").substring(7);
    	String userId = jwtUtil.extractUsername(token);   // ✅ CORRECT
    	
        return service.toggleLike(postId, userId);
    }

    @GetMapping("/{postId}")
    public long getLikes(@PathVariable Long postId) {
        return service.getLikeCount(postId);
    }
}