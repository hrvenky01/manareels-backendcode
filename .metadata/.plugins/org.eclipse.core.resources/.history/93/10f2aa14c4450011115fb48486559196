package com.manareels.service;

import com.manareels.dto.PostRequest;
import com.manareels.dto.PostResponse;
import com.manareels.model.Post;
import com.manareels.model.User;
import com.manareels.repository.PostRepository;
import com.manareels.repository.UserRepository;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.util.List;
import java.util.stream.Collectors;

@Service
public class PostService {

    @Autowired
    private PostRepository postRepository;

    @Autowired
    private UserRepository userRepository;

    // CREATE POST
    public PostResponse createPost(Long userId, PostRequest request) {

        User user = userRepository.findById(userId)
                .orElseThrow(() -> new RuntimeException("User not found"));

        Post post = new Post();
        post.setCaption(request.getCaption());
        post.setVideoUrl(request.getVideoUrl());
        post.setImageUrl(request.getImageUrl());
        post.setUser(user);

        Post saved = postRepository.save(post);

        return mapToResponse(saved);
    }

    // GET FEED
    public List<PostResponse> getAllPosts() {
        return postRepository.findAllByOrderByCreatedAtDesc()
                .stream()
                .map(this::mapToResponse)
                .collect(Collectors.toList());
    }

    // MAPPER
    private PostResponse mapToResponse(Post post) {
        PostResponse res = new PostResponse();
        res.setId(post.getId());
        res.setCaption(post.getCaption());
        res.setVideoUrl(post.getVideoUrl());
        res.setUsername(post.getUser().getUsername());
        res.setCreatedAt(post.getCreatedAt());
        return res;
    }
}