package com.manareels.service;

import com.manareels.model.Like;
import com.manareels.repository.LikeRepository;
import org.springframework.stereotype.Service;

import java.util.Optional;

@Service
public class LikeService {

    private final LikeRepository repository;

    public LikeService(LikeRepository repository) {
        this.repository = repository;
    }

    // ❤️ TOGGLE LIKE (FIXED)
    public String toggleLike(Long postId, Long userId) {

        Optional<Like> existing = repository.findByPostIdAndUserId(postId, userId);

        if (existing.isPresent()) {
            repository.delete(existing.get());
            return "Unliked";
        } else {
            Like like = new Like();
            like.setPostId(postId);
            like.setUserId(userId);
            repository.save(like);
            return "Liked";
        }
    }

    // 🔢 COUNT
    public long getLikeCount(Long postId) {
        return repository.countByPostId(postId);
    }
}