package com.manareels.controller;

import com.manareels.security.JwtUtil;
import org.springframework.web.bind.annotation.*;

import jakarta.servlet.http.HttpServletRequest;

@RestController
@RequestMapping("/api/posts")
public class PostController {

    private final JwtUtil jwtUtil;

    public PostController(JwtUtil jwtUtil) {
        this.jwtUtil = jwtUtil;
    }

    // 🔐 Protected API example
    @PostMapping("/create")
    public String createPost(
            @RequestBody String postContent,
            HttpServletRequest request
    ) {

        // 1️⃣ Authorization header read cheyyi
        String authHeader = request.getHeader("Authorization");

        if (authHeader == null || !authHeader.startsWith("Bearer ")) {
            return "Unauthorized - Token missing";
        }

        // 2️⃣ Token extract cheyyi
        String token = authHeader.substring(7);

        // 3️⃣ Username (email) extract cheyyi ✅
        String email = jwtUtil.extractUsername(token);

        // 👉 ikkada DB lo post save logic vastundi (later)
        return "Post created by user: " + email;
    }
}